{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "skipLibCheck": true,
    "types": ["node"]
  },
  "exclude": ["node_modules", "**/node_modules/**/tsconfig.json"],
  "include": ["**/*.ts", "**/*.tsx", "nativewind-env.d.ts"]
}
