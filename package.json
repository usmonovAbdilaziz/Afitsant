{
  "name": "easybooking",
  "private": true,
  "scripts": {
    "start": "node --env-file=.env dist/index.js",
    "start:dev": "tsx watch --env-file=.env --no-deprecation -r tsconfig-paths/register index.ts",
    "build": "([ -d generated ] || npm run prisma:generate) && rm -rf dist && tsc && tsc-alias -p tsconfig.json && cp -r generated dist/",
    "build:bun": "bun build --compile --minify-whitespace --minify-syntax --target=bun --outfile=server index.ts",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prisma:migration": "prisma migrate dev --name init",
    "prisma:seed": "tsx --env-file=.env -r tsconfig-paths/register prisma/seed.ts",
    "prisma:migration:prod": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "prisma:format": "prisma format",
    "android": "npm run --prefix mobile android",
    "ios": "npm run --prefix mobile ios",
    "mobile": "npm run --prefix mobile start"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.4.0",
    "@prisma/adapter-pg": "^7.0.1",
    "@prisma/client": "^7.0.1",
    "@types/multer": "^2.0.0",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-redis-cache": "^1.1.3",
    "grammy": "^1.38.4",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "pg": "^8.16.3",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tsconfig/recommended": "^1.0.13",
    "@types/bun": "^1.3.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.2",
    "@types/pg": "^8.15.6",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.39.1",
    "prettier": "^3.7.3",
    "prisma": "^7.0.1",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1"
  },
  "version": "1.0.0"
}
