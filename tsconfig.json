{
  "extends": "@tsconfig/recommended/tsconfig.json",
  "compilerOptions": {
    "baseUrl": "./",
    "outDir": "dist",
    "paths": {
      "@/*": ["src/*"],
      "@/lib/*": ["lib/*"],
      "@/generated/*": ["generated/*"],
      "@/config/*": ["src/config/*"],
      "@/middleware/*": ["src/middleware/*"],
      "@/routes/*": ["src/routes/*"],
      "@/services/*": ["src/services/*"],
      "@/types/*": ["src/types/*"],
      "@/utils/*": ["src/utils/*"],
      "@/controllers/*": ["src/controllers/*"],
      "@/validators/*": ["src/validators/*"]
    }
  },
  "exclude": ["node_modules", "prisma/seed.ts", "mobile", "web"]
}
